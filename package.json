{
  "name": "tapw",
  "private": true,
  "version": "0.0.0",
  "author": "David Adamson",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "format": "prettier --ignore-path .gitignore --write .",
    "check:format": "prettier --ignore-path .gitignore --check .",
