    "@vitejs/plugin-vue": "^6.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cypress": "^15.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "hono": "^4.12.8",
    "lucide-vue-next": "^0.577.0",
